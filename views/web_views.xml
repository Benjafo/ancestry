<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
    
        <template id="assets_backend" name="ancestry assets" inherit_id="web.assets_backend">
            <xpath expr="." position="inside">
                <script type="text/javascript" src="/ancestry/static/src/js/ancestry_models.js"></script>
                <script type="text/javascript" src="/ancestry/static/src/js/ancestry_renderers.js"></script>
                <script type="text/javascript" src="/ancestry/static/src/js/ancestry_views.js"></script>
            </xpath>
        </template>
        <template id="family_tree_view" name="Family Tree View">
            <t t-call="web.OwlView">
                <t t-set="widget" t-value="widgetManager.create_widget('family_tree', state)" />
                <t t-esc="widget.render()" />
            </t>
        </template>

        <!-- Menu item for accessing the Family Tree view -->
        <menuitem id="menu_family_tree" name="Family Tree" parent="ancestry.menu_root" action="action_family_tree" sequence="10"/>

        <!-- Action for the Family Tree view -->
        <record id="action_family_tree" model="ir.actions.act_window">
            <field name="name">Family Tree</field>
            <field name="res_model">ancestry.ancestry_ancesty</field>
            <field name="view_mode">kanban</field>
            <!-- Add other necessary fields -->
        </record>
    </data>
</odoo>