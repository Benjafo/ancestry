<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_marriage_wizard" model="ir.ui.view">
        <field name="name">Create a Marriage Link</field>
        <field name="model">marriage.wizard</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <field name="spouse_one"/>
                    <field name="spouse_two"/>
                </group>
                <footer>
                    <button string="Confirm" name="confirm_marriage" type="object" class="oe_highlight"/>
                    <button string="Cancel" class="btn btn-default" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
